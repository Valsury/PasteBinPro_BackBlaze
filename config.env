# Flask конфигурация
SECRET_KEY=your-super-secret-key-change-this-in-production
FLASK_ENV=production
FLASK_DEBUG=0

# PostgreSQL конфигурация (Render автоматически установит DATABASE_URL)
DATABASE_URL=postgresql://pastebin_user:pastebin_password@localhost:5432/pastebin_db

# Хранилище (выберите один вариант)
# Вариант 1: Backblaze B2 (10 GB бесплатно, рекомендуется)
# Вариант 2: Локальное хранилище (для тестов, данные теряются при рестарте)
# Вариант 3: Cloudflare R2 (10 GB бесплатно)

# Тип хранилища: s3 или local
STORAGE_TYPE=s3

# Для локального хранилища (STORAGE_TYPE=local)
STORAGE_PATH=./storage/pastes

# Для S3-совместимого хранилища (STORAGE_TYPE=s3)
# Backblaze B2: S3_ENDPOINT=s3.us-west-004.backblazeb2.com
# Cloudflare R2: S3_ENDPOINT=<account-id>.r2.cloudflarestorage.com
# MinIO (локально): S3_ENDPOINT=localhost:9000
S3_ENDPOINT=s3.us-west-004.backblazeb2.com
S3_ACCESS_KEY=your-backblaze-keyID
S3_SECRET_KEY=your-backblaze-applicationKey
S3_BUCKET_NAME=pastebin-pastes
S3_SECURE=true
S3_REGION=us-west-004

# Обратная совместимость с MinIO (будут использоваться если S3_* не установлены)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=pastes
MINIO_SECURE=false

# LLM API конфигурация (бесплатные модели на OpenRouter)
LLM_PROVIDER=openrouter
LLM_API_KEY=your-openrouter-api-key
# Бесплатные модели (не требуют пополнения):
# - mistralai/mistral-7b-instruct (рекомендуется)
# - google/gemini-flash-1.5
# - meta-llama/llama-3-8b-instruct
LLM_MODEL=mistralai/mistral-7b-instruct
# Для custom провайдера укажите базовый URL
LLM_BASE_URL=http://localhost:11434/v1

# URL приложения (для OpenRouter referrer)
APP_URL=http://localhost:5000

# Устаревшие настройки Ollama (для обратной совместимости)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2
